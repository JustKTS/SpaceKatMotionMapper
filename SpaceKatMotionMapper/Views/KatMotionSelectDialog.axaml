<UserControl
    x:Class="SpaceKatMotionMapper.Views.KatMotionSelectDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:SpaceKatMotionMapper.ViewModels"
    x:DataType="vm:KatMotionSelectDialogViewModel"
    x:Name="RootControl"
    Width="550"
    Height="380">

    <Design.DataContext>
        <vm:KatMotionSelectDialogViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <!-- 运动选择项按钮样式 - 使用 Semi 主题色 -->
        <Style Selector="Button.MotionItem">
            <Setter Property="Background" Value="{DynamicResource SemiColorBackground2}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="500" />
            <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                    <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.MotionItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ButtonDefaultPointeroverBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SemiColorPrimary}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.MotionItem:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SemiColorPrimaryLight}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SemiColorPrimary}" />
            <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="24" RowDefinitions="Auto,*">
        <!-- 标题 -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock
                Classes="H3"
                Text="请选择要添加的3D旋钮运动"
                Theme="{StaticResource TitleTextBlock}" />
            <TextBlock
                Text="点击运动类型即可添加"
                Classes="H6"
                Foreground="{DynamicResource SemiColorText2}" />
        </StackPanel>

        <!-- 运动网格 -->
        <Border
            Grid.Row="1"
            Classes="Shadow"
            Margin="0"
            Theme="{StaticResource CardBorder}"
            VerticalAlignment="Stretch">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding AvailableMotions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:MotionOption">
                            <Button
                                Classes="MotionItem"
                                Command="{Binding DataContext.SelectMotionCommand, ElementName=RootControl}"
                                CommandParameter="{Binding Motion}"
                                MinWidth="100"
                                MinHeight="44"
                                HorizontalAlignment="Stretch"
                                Margin="6">
                                <TextBlock
                                    Text="{Binding DisplayName}"
                                    Classes="H5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    TextWrapping="Wrap"
                                    TextAlignment="Center" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
