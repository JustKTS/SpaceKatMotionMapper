<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SpaceKatMotionMapper.ViewModels"
             x:Class="SpaceKatMotionMapper.Views.CloseConfirmDialog"
             x:DataType="vm:CloseConfirmDialogViewModel"
             mc:Ignorable="d">

    <Design.DataContext>
        <vm:CloseConfirmDialogViewModel />
    </Design.DataContext>

    <StackPanel Margin="24" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
        <TextBlock Text="确认要退出程序吗？"
                   Classes="H5"
                   HorizontalAlignment="Center" />

        <TextBlock Text="缩小到托盘请使用最小化按钮。"
                   FontSize="13"
                   Foreground="{DynamicResource SemiColorTertiary}"
                   HorizontalAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Margin="0,8,0,0">
            <Button Command="{Binding CancelCommand}"
                    Content="取消"
                    Theme="{DynamicResource OutlineButton}"
                    Width="80" />
            <Button Command="{Binding ConfirmCommand}"
                    Content="退出"
                    Classes="Danger"
                    Width="80" />
        </StackPanel>
    </StackPanel>
</UserControl>
