<UserControl
    Background="{DynamicResource SemiColorBackground2}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="SpaceKat.Shared.Views.KeyActionConfigV2Control"
    x:DataType="vm:KeyActionConfigV2ViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SpaceKat.Shared.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:SpaceKat.Shared.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.DataContext>
        <vm:KeyActionConfigV2ViewModel />
    </Design.DataContext>


    <UserControl.Styles>
        <Style Selector="Border.WrongDefine">
            <Setter Property="Background" Value="{DynamicResource SemiColorDanger}" />
        </Style>
        <Style Selector="ToggleButton.Borderless">
            <Setter Property="CornerRadius" Value="5" />
        </Style>
        <Style Selector="ToggleButton.Borderless:unchecked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ButtonBorderlessBackground}" />
        </Style>
        <Style Selector="ToggleButton.Borderless:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ButtonDefaultPointeroverBackground}" />
        </Style>
    </UserControl.Styles>

    <!--  <Border  -->
    <!--  Classes="Shadow"  -->
    <!--  Padding="5"  -->
    <!--  Theme="{StaticResource CardBorder}">  -->
    <Grid RowDefinitions="Auto, *">
        <Grid ColumnDefinitions="Auto, Auto, *,Auto">
            <StackPanel
                Margin="5"
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock
                    Classes="H4"
                    Theme="{StaticResource TitleTextBlock}"
                    VerticalAlignment="Center">
                    按键配置
                </TextBlock>
            </StackPanel>
            <Border
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                Margin="5"
                Theme="{StaticResource RadioButtonGroupBorder}"
                VerticalAlignment="Stretch">
                <StackPanel Orientation="Horizontal">
                    <RadioButton
                        IsChecked="True"
                        Name="CombinationRBtn"
                        Theme="{DynamicResource ButtonRadioButton}"
                        VerticalContentAlignment="Center">
                        组合/单键
                    </RadioButton>
                    <RadioButton
                        Name="MacroRBtn"
                        Theme="{DynamicResource ButtonRadioButton}"
                        VerticalContentAlignment="Center">
                        宏
                    </RadioButton>
                </StackPanel>
            </Border>

            <TextBox
                Grid.Column="2"
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding $parent[local:KeyActionConfigV2Control].IsCustomDescription}"
                Margin="5"
                Text="{Binding KeyActionsDescription, Mode=TwoWay}"
                VerticalAlignment="Stretch"
                PlaceholderText="自定义动作描述" />
        </Grid>

        <Panel Grid.Row="1" Margin="5">
            <local:CombinationKeyActionConfigControl DataContext="{Binding CombinationKeysWithCommandVM}" IsVisible="{Binding #CombinationRBtn.IsChecked}" />
            <Border
                Background="{DynamicResource SemiColorBackground3}"
                Classes="Shadow"
                IsVisible="{Binding #MacroRBtn.IsChecked}"
                Padding="5"
                Theme="{StaticResource CardBorder}">
                <ScrollViewer MaxHeight="500">
                    <local:KeyActionsItemsControl DataContext="{Binding ActionConfigGroups}" Margin="10" />
                </ScrollViewer>
            </Border>
        </Panel>
    </Grid>
    <!-- </Border> -->
</UserControl>